<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="@color/ef_domains_bg_bottom"
                android:startColor="@color/ef_domains_bg_top"
                android:type="linear" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.85"
                android:centerY="0.12"
                android:gradientRadius="320dp"
                android:startColor="#18FFFFFF"
                android:endColor="#00000000"
                android:type="radial" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.1"
                android:centerY="0.9"
                android:gradientRadius="380dp"
                android:startColor="#12A7D7C8"
                android:endColor="#00000000"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
