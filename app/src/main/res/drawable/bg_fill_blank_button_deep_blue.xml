<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom Depth/Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/ef_deep_sea_blue_dark" />
        </shape>
    </item>

    <!-- Main Surface -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="270"
                android:endColor="@color/ef_deep_sea_blue"
                android:startColor="@color/ef_deep_sea_blue_light" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
