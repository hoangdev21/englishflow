<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:startColor="#154CAF50"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    <!-- Main Ring -->
    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#40A5D6A7"
                android:dashWidth="40dp"
                android:dashGap="120dp" />
        </shape>
    </item>
    <!-- Floating Particles Simulation (Just another ring for now) -->
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#20FFFFFF"
                android:dashWidth="120dp"
                android:dashGap="40dp" />
        </shape>
    </item>
</layer-list>
