<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <!-- Physical Depth Shadow (Bottom) -->
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="24dp" />
                    <solid android:color="#3594A3B8" />
                </shape>
            </item>
            <!-- Middle Soft Shadow -->
            <item android:bottom="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="24dp" />
                    <solid android:color="#5094A3B8" />
                </shape>
            </item>
            <!-- Main Button Highlight (Silver Border) -->
            <item android:bottom="5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="24dp" />
                    <stroke android:width="1.8dp" android:color="#E2E8F0" />
                    <gradient
                        android:angle="270"
                        android:centerY="0.1"
                        android:endColor="#F8FAFC"
                        android:startColor="#FFFFFF"
                        android:type="linear" />
                </shape>
            </item>
            <!-- Inner Glass Highlight -->
            <item android:bottom="7dp" android:top="1dp" android:left="3dp" android:right="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="22dp" />
                    <gradient
                        android:angle="90"
                        android:endColor="#25FFFFFF"
                        android:startColor="@android:color/transparent"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <!-- Inactive state -->
        <ripple android:color="#15000000">
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="24dp" />
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>
