<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#12000000" />
        </shape>
    </item>

    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#F2FFFB"
                android:endColor="#DAF2E9" />
            <stroke
                android:width="1dp"
                android:color="#A7D9CA" />
        </shape>
    </item>
</layer-list>