<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow/Bottom depth -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/ef_silver_shadow" />
        </shape>
    </item>

    <!-- Main Surface -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/ef_surface_elevated" />
            <stroke
                android:width="1dp"
                android:color="@color/ef_outline_light" />
        </shape>
    </item>
</layer-list>
