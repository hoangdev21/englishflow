<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ambient shadow -->
    <item android:left="0dp" android:top="3dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#0F000000" />
        </shape>
    </item>

    <!-- soft pastel surface -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="135"
                android:startColor="@color/ef_learn_card_pink"
                android:centerColor="@color/ef_learn_card_blue"
                android:endColor="@color/ef_learn_card_green" />
        </shape>
    </item>

    <!-- subtle top gloss -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="90"
                android:startColor="#33FFFFFF"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- border -->
    <item android:left="0dp" android:top="0dp" android:right="0dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="@color/ef_outline_light" />
        </shape>
    </item>

</layer-list>

