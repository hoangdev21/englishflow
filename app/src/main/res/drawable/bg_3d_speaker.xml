<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Shadow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#7094A3B8" />
        </shape>
    </item>

    <!-- Mid Shadow -->
    <item android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#9094A3B8" />
        </shape>
    </item>

    <!-- Main Body -->
    <item android:bottom="4dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#CBD5E1" />
            <gradient
                android:angle="270"
                android:centerY="0.2"
                android:endColor="#F1F5F9"
                android:startColor="#FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Glossy -->
    <item android:bottom="6dp" android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <gradient
                android:angle="90"
                android:endColor="#20FFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
