<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="4dp" android:topRightRadius="22dp" android:bottomLeftRadius="22dp" android:bottomRightRadius="22dp" />
            <solid android:color="#0D475669" />
        </shape>
    </item>

    <!-- Content -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="4dp" android:topRightRadius="22dp" android:bottomLeftRadius="22dp" android:bottomRightRadius="22dp" />
            <stroke android:width="1dp" android:color="#E2E8F0" />
            <gradient
                android:angle="270"
                android:endColor="#F8FAFC"
                android:startColor="#FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
