<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep Depth Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="22dp" android:topRightRadius="4dp" android:bottomLeftRadius="22dp" android:bottomRightRadius="22dp" />
            <solid android:color="#20077A5F" />
        </shape>
    </item>

    <!-- Content Card -->
    <item android:bottom="3dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="22dp" android:topRightRadius="4dp" android:bottomLeftRadius="22dp" android:bottomRightRadius="22dp" />
            <gradient
                android:angle="270"
                android:endColor="@color/ef_primary"
                android:startColor="@color/ef_primary_light"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Glow -->
    <item android:bottom="4dp" android:left="3dp" android:right="3dp" android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="20dp" android:topRightRadius="2dp" android:bottomLeftRadius="20dp" android:bottomRightRadius="20dp" />
            <gradient
                android:angle="90"
                android:endColor="#1AFFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
