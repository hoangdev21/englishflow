<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Shape -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:endColor="#150D9373"
                android:startColor="#250D9373"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#200D9373" />
            <size android:width="44dp" android:height="44dp" />
        </shape>
    </item>
</layer-list>
