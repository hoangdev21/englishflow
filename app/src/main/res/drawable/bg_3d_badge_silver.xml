<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main 3D Deep Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#7094A3B8" />
        </shape>
    </item>

    <!-- Mid Shadow (For softness) -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#9094A3B8" />
        </shape>
    </item>

    <!-- Main Button Body (Silver/White Gradient) -->
    <item android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke android:width="1.5dp" android:color="#CBD5E1" />
            <gradient
                android:angle="270"
                android:centerY="0.2"
                android:endColor="#F1F5F9"
                android:startColor="#FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Glossy Highlight -->
    <item android:bottom="8dp" android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="90"
                android:endColor="#20FFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
