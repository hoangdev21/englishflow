<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main 3D Deep Shadow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#70059669" />
        </shape>
    </item>

    <!-- Mid Shadow -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <solid android:color="#90059669" />
        </shape>
    </item>

    <!-- Main Button Body (Green) -->
    <item android:bottom="5dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <stroke android:width="1.2dp" android:color="#059669" />
            <gradient
                android:angle="270"
                android:centerY="0.2"
                android:endColor="#D1FAE5"
                android:startColor="#F0FDF4"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Glossy Highlight -->
    <item android:bottom="7dp" android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="30dp" />
            <gradient
                android:angle="90"
                android:endColor="#30FFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
