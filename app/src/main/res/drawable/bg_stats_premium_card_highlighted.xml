<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow / Base Depth Layer -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/ef_primary_dark" />
        </shape>
    </item>

    <!-- Main Card Body -->
    <item android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="@color/ef_primary" />
            <gradient
                android:angle="270"
                android:centerY="0.2"
                android:endColor="@color/ef_primary_container"
                android:startColor="#FFFFFF"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Highlight (Subtle Shine) -->
    <item android:bottom="5dp" android:top="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="90"
                android:endColor="#1AFFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
