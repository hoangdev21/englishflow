<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="#DCEDE7" />
            <stroke
                android:width="1dp"
                android:color="@color/ef_domains_card_stroke" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFFFFFFF"
                android:endColor="#F4FAF7"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="@color/ef_domains_card_stroke" />
        </shape>
    </item>
</selector>
