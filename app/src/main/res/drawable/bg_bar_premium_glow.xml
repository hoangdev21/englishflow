<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active Neon Glow Overlay (Soft Shadow for Neon feel) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#253B82F6" />
        </shape>
    </item>

    <!-- Main Active Bar (3D Gradient) -->
    <item android:bottom="0dp" android:left="1dp" android:right="1dp" android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="270"
                android:startColor="#60A5FA"
                android:endColor="#2563EB"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#93C5FD" />
        </shape>
    </item>

    <!-- Top Gloss Highlight (Premium Glass Feel) -->
    <item android:bottom="10dp" android:left="3dp" android:right="3dp" android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:angle="90"
                android:endColor="#40FFFFFF"
                android:startColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
