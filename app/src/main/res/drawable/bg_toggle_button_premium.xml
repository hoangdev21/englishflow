<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked (Selected) State -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="@color/ef_primary_dark" />
                </shape>
            </item>
            <item android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="@color/ef_primary" />
                    <gradient
                        android:angle="270"
                        android:endColor="@color/ef_primary"
                        android:startColor="@color/ef_primary_light" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default (Unchecked) State -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#F1F5F9" />
            <stroke android:width="1dp" android:color="#E2E8F0" />
        </shape>
    </item>
</selector>
