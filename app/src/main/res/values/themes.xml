<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base Widget Style -->
    <style name="Widget" parent="android:Widget" />

    <!-- Base Style for EnglishFlow Theme -->
    <style name="Base.Theme.EnglishFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ef_primary</item>
        <item name="colorPrimaryDark">@color/ef_primary_dark</item>
        <item name="colorAccent">@color/ef_secondary</item>
        <item name="android:colorBackground">@color/ef_background</item>
        <item name="android:windowBackground">@color/ef_background</item>
        <item name="android:fontFamily">@font/nunito</item>
        <item name="fontFamily">@font/nunito</item>
        <item name="android:statusBarColor">@color/ef_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.EnglishFlow" parent="Base.Theme.EnglishFlow" />

    <style name="Theme.EnglishFlow.Splash" parent="Theme.EnglishFlow">
        <item name="android:windowBackground">@drawable/bg_splash_gradient</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#077A5F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.EnglishFlow.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ef_text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.EnglishFlow.Headline" parent="TextAppearance.AppCompat.Title">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ef_text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:letterSpacing">-0.015</item>
    </style>

    <style name="TextAppearance.EnglishFlow.Body" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/ef_text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="TextAppearance.EnglishFlow.Label" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/ef_text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.EnglishFlow.Caption" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textColor">@color/ef_text_tertiary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.EnglishFlow" tools:ignore="ResourceCycle">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/ef_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.EnglishFlow.Card" tools:ignore="ResourceCycle">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/ef_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.EnglishFlow.Card.Elevated" tools:ignore="ResourceCycle">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.EnglishFlow.BottomIndicator">
        <item name="android:color">@null</item>
        <item name="android:drawable">@drawable/bg_nav_indicator</item>
    </style>

    <!-- Premium Button Styles -->
    <style name="Widget.Material3.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/ef_on_primary</item>
        <item name="android:backgroundTint">@color/ef_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="Widget.Material3.Button.TonalButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/ef_on_primary_container</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="android:backgroundTint">@color/ef_primary_container</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Material3.Button.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/ef_primary</item>
        <item name="strokeColor">@color/ef_outline</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Material3.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/ef_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Custom Bottom Sheet Dialog Style -->
    <style name="CustomBottomSheetDialogTheme" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="RoundedAvatarStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="CircleAvatarStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TransparentDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Widget.EnglishFlow.Admin.FilterChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/admin_filter_chip_bg</item>
        <item name="android:textColor">@color/admin_filter_chip_text</item>
        <item name="chipStrokeColor">@color/ef_outline</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipMinHeight">30dp</item>
        <item name="chipCornerRadius">15dp</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
        <item name="iconStartPadding">4dp</item>
        <item name="iconEndPadding">4dp</item>
        <item name="textStartPadding">2dp</item>
        <item name="textEndPadding">2dp</item>
        <item name="checkedIconSize">14dp</item>
        <item name="checkedIconTint">@color/black</item>
        <item name="rippleColor">@color/ef_outline_light</item>
        <item name="ensureMinTouchTargetSize">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <style name="ef_dialog_rounded" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>
</resources>