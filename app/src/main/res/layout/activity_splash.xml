<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Moving starry sky background -->
    <com.example.englishflow.ui.views.StarrySkyView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Realistic Sea Waves at bottom -->
    <ImageView
        android:id="@+id/waveDeep"
        android:layout_width="1200dp"
        android:layout_height="220dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="-40dp"
        android:src="@drawable/bg_splash_wave_deep"
        android:scaleType="matrix"
        android:alpha="0.3" />

    <ImageView
        android:id="@+id/waveMid"
        android:layout_width="1200dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="-30dp"
        android:src="@drawable/bg_splash_wave_mid"
        android:scaleType="matrix"
        android:alpha="0.5" />

    <ImageView
        android:id="@+id/waveFront"
        android:layout_width="1200dp"
        android:layout_height="140dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="-20dp"
        android:src="@drawable/bg_splash_wave_front_new"
        android:scaleType="matrix"
        android:alpha="0.8" />

    <!-- Glow effect behind logo -->
    <View
        android:id="@+id/logoGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:alpha="0"
        android:background="@drawable/bg_splash_glow" />

    <!-- Centered Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/english_flow"
            android:padding="5dp" />

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="36sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#FFFFFF"
            android:letterSpacing="-0.03"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="4" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Nâng tầm tri thức mỗi ngày"
            android:textSize="14sp"
            android:letterSpacing="0.05"
            android:textColor="#CBD5E1"
            android:alpha="0.9" />

    </LinearLayout>

    <!-- Bottom loading -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/splashLoader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:indeterminate="true"
        app:indicatorColor="#FFFFFF"
        app:indicatorSize="24dp"
        app:trackThickness="2dp"
        android:alpha="0.5" />

</FrameLayout>
