<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Decorative orbs -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-30dp"
        android:background="@drawable/bg_auth_orb_top"
        android:importantForAccessibility="no" />

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-60dp"
        android:layout_marginBottom="-40dp"
        android:background="@drawable/bg_auth_orb_bottom"
        android:importantForAccessibility="no" />

    <!-- Centered Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="28dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/english_flow"
            android:scaleType="centerInside" />

        <!-- Title -->
        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nâng trình anh ngữ hàng ngày"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:alpha="0.85"
            android:layout_marginBottom="40dp" />

        <!-- Loading Indicator -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="#FFFFFF"
            app:trackColor="#40FFFFFF"
            app:trackCornerRadius="4dp"
            app:trackThickness="3dp" />
    </LinearLayout>

</FrameLayout>
