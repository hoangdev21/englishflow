<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_background">

    <LinearLayout
        android:id="@+id/adminLessonDetailTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_profile_hero_gamified"
        android:elevation="8dp"
        android:fitsSystemWindows="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackAdminLessonDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_back_button_premium"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_back_arrow"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            app:rippleColor="#33FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:text="@string/admin_lesson_detail_screen_title"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/adminLessonDetailScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ProgressBar
                android:id="@+id/adminLessonDetailLoading"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/adminLessonDetailError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_warning_block"
                android:padding="12dp"
                android:textColor="@color/ef_warning_text"
                android:textSize="13sp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_lesson_detail_section_domain_tasks"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/adminLessonDetailDomainFilterInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:dropDownHeight="260dp"
                        android:hint="@string/admin_lesson_detail_domain_hint"
                        android:inputType="none"
                        android:maxLines="1"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/adminLessonDetailTaskCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/adminLessonDetailTaskContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/adminLessonDetailTaskEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/admin_lesson_detail_task_empty"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/adminLessonDetailEmoji"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_learn_quick_action_tile"
                        android:gravity="center"
                        android:text="📘"
                        android:textSize="26sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/adminLessonDetailTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lesson title"
                            android:textColor="@color/black"
                            android:textSize="21sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/adminLessonDetailLessonId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="lesson_01"
                            android:textColor="@color/ef_text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/adminLessonDetailStatusChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_tag_blue"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="PUBLISHED"
                        android:textColor="@color/ef_card_blue_text"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/adminLessonDetailLevelChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_tag_emerald"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="A1"
                        android:textColor="@color/ef_primary"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/adminLessonDetailMetaPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="lesson_01 • A1 • thứ tự 1"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/adminLessonDetailMetaSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="3 từ • tối thiểu 4 lượt trao đổi"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_lesson_detail_section_context"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/adminLessonDetailRoleDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/admin_lesson_detail_prompt_key_label"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/adminLessonDetailPromptKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_chip_soft"
                    android:padding="10dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_lesson_detail_section_edit"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAdminLessonEditTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_lesson_detail_edit_title_hint"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxBackgroundColor="@color/ef_surface"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ef_outline"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputAdminLessonEditLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/admin_lesson_detail_edit_level_hint"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/ef_text_primary"
                            android:textColorHint="@color/ef_text_tertiary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:boxBackgroundColor="@color/ef_surface"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ef_outline"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputAdminLessonEditOrder"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/admin_lesson_detail_edit_order_hint"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/ef_text_primary"
                            android:textColorHint="@color/ef_text_tertiary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAdminLessonEditDomain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_lesson_detail_edit_domain_hint"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:boxBackgroundColor="@color/ef_surface"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ef_outline"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputAdminLessonEditStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/admin_lesson_detail_edit_status_hint"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/ef_text_primary"
                            android:textColorHint="@color/ef_text_tertiary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:boxBackgroundColor="@color/ef_surface"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ef_outline"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputAdminLessonEditMinExchanges"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/admin_lesson_detail_edit_min_exchanges_hint"
                            android:inputType="number"
                            android:maxLines="1"
                            android:textColor="@color/ef_text_primary"
                            android:textColorHint="@color/ef_text_tertiary"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAdminLessonEditKeywords"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_lesson_detail_edit_keywords_hint"
                        android:inputType="textCapSentences"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAdminLessonEditPromptKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/admin_lesson_detail_edit_prompt_key_hint"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/ef_surface"
                    app:boxBackgroundMode="outline"
                    app:boxStrokeColor="@color/ef_outline"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputAdminLessonEditRole"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:hint="@string/admin_lesson_detail_edit_role_hint"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="3"
                        android:textColor="@color/ef_text_primary"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdminLessonDetailSaveChanges"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/admin_lesson_detail_save_changes"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/ef_primary"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_check_circle"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_lesson_detail_section_keywords"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/adminLessonDetailKeywordContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <TextView
                    android:id="@+id/adminLessonDetailKeywordEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/admin_lesson_detail_keywords_empty"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_lesson_detail_section_vocabulary"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminLessonDetailAddVocabulary"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text="@string/admin_lesson_detail_add_vocabulary"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/ef_primary_container"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="14dp"
                        app:iconTint="@color/ef_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/adminLessonDetailVocabularyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/adminLessonDetailVocabularyEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/admin_lesson_detail_vocabulary_empty"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_settings_card_white"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_lesson_detail_section_flow"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAdminLessonDetailAddFlowStep"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text="@string/admin_lesson_detail_add_flow_step"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/ef_primary_container"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="14dp"
                        app:iconTint="@color/ef_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/adminLessonDetailFlowContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/adminLessonDetailFlowEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/admin_lesson_detail_flow_empty"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
