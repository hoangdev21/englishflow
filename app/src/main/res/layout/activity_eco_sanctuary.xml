<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ecoRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_eco_sanctuary_surface">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/ecoScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="64dp">

            <!-- Mascot Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <FrameLayout
                    android:id="@+id/ecoMascotContainer"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="10dp">
                    
                    <com.example.englishflow.ui.views.EcoMascot3DView
                        android:id="@+id/ecoMascotView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </FrameLayout>

                <TextView
                    android:id="@+id/ecoStageText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_eco_chip"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="8dp"
                    android:text="Mầm cánh"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/ecoMoodText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Đang tò mò khám phá"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:alpha="0.7" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/ecoBondProgress"
                    style="@style/Widget.MaterialComponents.LinearProgressIndicator"
                    android:layout_width="240dp"
                    android:layout_height="12dp"
                    android:layout_marginTop="20dp"
                    android:indeterminate="false"
                    app:indicatorColor="@color/ef_primary"
                    app:trackColor="#15000000"
                    app:trackCornerRadius="6dp" />

                <TextView
                    android:id="@+id/ecoBondText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Sức mạnh: 0 / 120"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp"
                    android:alpha="0.6" />
            </LinearLayout>

            <!-- Missions Bottom Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="12dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.MaterialCardView.RoundedTop">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="28dp"
                    android:paddingBottom="48dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nuôi thú cưng"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/ecoLevelBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cấp 1"
                            android:textColor="@color/ef_primary"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/ecoMissionSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Hoàn thành 0/4 nhiệm vụ hằng ngày"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#08000000"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/ecoMissionRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Wallet Section inside Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="12dp"
                        android:background="@drawable/bg_eco_chip"
                        android:layout_marginTop="24dp">

                        <TextView
                            android:id="@+id/ecoWalletXp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="XP: 0"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        
                        <View android:layout_width="1dp" android:layout_height="14dp" android:background="#15000000" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                        <TextView
                            android:id="@+id/ecoWalletSeeds"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hạt giống: 0"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="Thời trang thú cưng"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/ecoSkinRecycler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:clipToPadding="false" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Top Bar fixed at top (Z-Index is higher because it is declared after scroll view) -->
    <LinearLayout
        android:id="@+id/ecoTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/ecoBtnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_eco_back_button"
            android:clickable="true"
            android:focusable="true"
            android:padding="12dp"
            android:elevation="4dp"
            android:src="@drawable/back_navigation"
            app:tint="@color/ef_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Thú cưng Eco 🦜"
            android:textColor="@color/ef_text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_eco_chip"
            android:paddingVertical="8dp"
            android:layout_marginHorizontal="40dp"
            android:elevation="2dp" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
