<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_background">

    <LinearLayout
        android:id="@+id/settingsTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_profile_hero_gamified"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="4dp"
        android:fitsSystemWindows="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_back_button_premium"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_back_arrow"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            app:rippleColor="#33FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Cài đặt"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01" />

        <Space
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="84dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="10dp"
        android:paddingEnd="16dp"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card_white"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tài khoản &amp; Hồ sơ"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/settingsAvatarPreview"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_avatar"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
                        app:strokeColor="@color/ef_outline"
                        app:strokeWidth="2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChooseAvatar"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginStart="16dp"
                        android:background="@drawable/bg_button_raised_secondary"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="Đổi ảnh đại diện"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_card_blue_text"
                        android:textSize="13sp"
                        app:backgroundTint="@null" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Tên hiển thị"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputDisplayName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Nhập tên của bạn"
                    android:inputType="textPersonName"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Email"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputProfileEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Email của bạn"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_raised_primary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Lưu thông tin"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_settings_card_white"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thiết lập học thông minh"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mục tiêu học mỗi ngày"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvDailyGoalValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 phút/ngày"
                        android:textColor="@color/ef_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderDailyGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:valueFrom="5"
                    android:valueTo="60"
                    android:stepSize="5"
                    android:value="15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Điều chỉnh theo thời lượng rảnh để giữ nhịp học đều mỗi ngày."
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/ef_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tốc độ giọng đọc AI"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvVoiceSpeedValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.0x - Bình thường"
                        android:textColor="@color/ef_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderVoiceSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:valueFrom="0.8"
                    android:valueTo="1.2"
                    android:stepSize="0.1"
                    android:value="1.0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Áp dụng cho Chat, từ vựng và các màn hình luyện phát âm."
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/ef_divider" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_voice_timeout_title"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvVoiceSilenceTimeoutValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.0s"
                        android:textColor="@color/ef_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderVoiceSilenceTimeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:valueFrom="0.5"
                    android:valueTo="3.0"
                    android:stepSize="0.1"
                    android:value="2.0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_voice_timeout_desc"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/settings_voice_timeout_applies"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_settings_card_white"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cài đặt trải nghiệm"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <!-- Theme Toggle Item -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chế độ tối"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Tiết kiệm pin và bảo vệ mắt"
                            android:textColor="@color/ef_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:switchMinWidth="52dp"
                        app:thumbTint="@color/switch_ios_thumb_tint"
                        app:trackTint="@color/switch_ios_track_tint"
                        app:useMaterialThemeColors="false" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/ef_divider" />

                <!-- Notifications Item -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông báo đẩy"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Bật để nhận thông báo mới nhất!"
                            android:textColor="@color/ef_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAdminNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:switchMinWidth="52dp"
                        app:thumbTint="@color/switch_ios_thumb_tint"
                        app:trackTint="@color/switch_ios_track_tint"
                        app:useMaterialThemeColors="false" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_settings_card_white"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hỗ trợ &amp; Thông tin"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_raised_white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Gửi phản hồi / Báo lỗi"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_edit"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/ef_card_blue_text"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRateApp"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_raised_white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Đánh giá ứng dụng 5 sao"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_ai_stars"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/ef_stat_xp"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTerms"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_raised_white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Điều khoản sử dụng"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_nav_learn"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/ef_text_secondary"
                    app:strokeWidth="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrivacy"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_raised_white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Chính sách bảo mật"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="start|center_vertical"
                    android:paddingStart="20dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_lock_closed"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/ef_text_secondary"
                    app:strokeWidth="0dp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
