<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="32dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <!-- AI Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="4dp"
        app:cardBackgroundColor="@color/ef_primary_container"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI"
                android:textColor="@color/ef_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- AI Message Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- English Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="@color/ef_surface_variant"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ENGLISH"
                        android:textColor="@color/ef_text_tertiary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPronounceEnglish"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_volume_up"
                        app:iconGravity="textStart"
                        app:iconSize="16dp"
                        app:iconTint="@color/ef_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtAiMessageEnglish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vietnamese Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="@color/ef_primary_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TIẾNG VIỆT"
                        android:textColor="@color/ef_on_primary_container"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:alpha="0.7" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPronounceVietnamese"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:minWidth="30dp"
                        android:minHeight="30dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_volume_up"
                        app:iconGravity="textStart"
                        app:iconSize="16dp"
                        app:iconTint="@color/ef_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtAiMessageVietnamese"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/ef_on_primary_container"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grammar Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/grammarCardContainer"
            app:cardBackgroundColor="@color/ef_secondary_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GỢI Ý"
                    android:textColor="@color/ef_on_secondary_container"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:alpha="0.7" />

                <TextView
                    android:id="@+id/txtGrammarCorrection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/ef_on_secondary_container"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Time -->
        <TextView
            android:id="@+id/txtAiTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:textColor="@color/ef_text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

</LinearLayout>