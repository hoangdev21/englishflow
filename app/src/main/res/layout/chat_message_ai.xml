<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="32dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- AI Icon -->
    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="🤖"
        android:textSize="24sp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="4dp" />

    <!-- AI Message Container -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- English Response Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/ef_surface_variant"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇬🇧 Tiếng Anh:"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPronounceEnglish"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:minWidth="32dp"
                        android:minHeight="32dp"
                        android:padding="0dp"
                        android:text="🔊"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtAiMessageEnglish"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vietnamese Response Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/ef_primary_container"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🇻🇳 Tiếng Việt:"
                        android:textColor="@color/ef_on_primary_container"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPronounceVietnamese"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:minWidth="32dp"
                        android:minHeight="32dp"
                        android:padding="0dp"
                        android:text="🔊"
                        android:textSize="16sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/txtAiMessageVietnamese"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/ef_on_primary_container"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grammar/Correction Section (optional) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/grammarCardContainer"
            app:cardBackgroundColor="@color/ef_secondary_container"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ Gợi ý:"
                    android:textColor="@color/ef_on_secondary_container"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtGrammarCorrection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/ef_on_secondary_container"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Time -->
        <TextView
            android:id="@+id/txtAiTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="4dp"
            android:textColor="@color/ef_text_secondary"
            android:textSize="11sp"
            android:alpha="0.6" />
    </LinearLayout>

</LinearLayout>