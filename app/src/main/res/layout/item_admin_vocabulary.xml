<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/ef_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ef_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/adminVocabWord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Word"
            android:textColor="@color/ef_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminVocabMeaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Meaning"
            android:textColor="@color/ef_text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/adminVocabMeta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="general • seed"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/adminVocabStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stats_premium_card"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="OPEN"
                android:textColor="@color/ef_card_blue_text"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminVocabEditButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="34dp"
                android:minWidth="34dp"
                app:backgroundTint="@color/ef_surface_variant"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconSize="14dp"
                app:iconTint="@color/ef_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminVocabLockButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="34dp"
                android:minWidth="34dp"
                app:backgroundTint="@color/ef_surface_variant"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_lock_open"
                app:iconGravity="textStart"
                app:iconSize="14dp"
                app:iconTint="@color/ef_primary" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
