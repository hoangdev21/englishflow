<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_learn_gradient_premium">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/chatHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:descendantFocusability="afterDescendants"
        app:elevation="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/chatHeaderContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_home_premium"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="4dp"
                android:paddingEnd="18dp"
                android:paddingBottom="4dp"
                android:elevation="4dp">

                <!-- Title + header actions in one row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:letterSpacing="-0.02"
                        android:text="Nói chuyện với Flow"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHistory"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_history"
                        app:iconSize="18dp"
                        app:iconTint="@color/ef_text_primary"
                        app:iconGravity="textStart"
                        android:elevation="15dp" />

                    <!-- New Chat Button (3D White) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNewChat"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_marginStart="6dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_add"
                        app:iconSize="18dp"
                        app:iconTint="@color/ef_text_primary"
                        app:iconGravity="textStart"
                        android:elevation="15dp" />
                </LinearLayout>


                <!-- Topic Selector Card (3D White) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_3d_badge_silver"
                    android:elevation="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="9dp"
                    android:paddingVertical="1dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="16sp" />

                    <Spinner
                        android:id="@+id/spinnerTopic"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="4dp"
                        android:background="@null"
                        android:dropDownWidth="190dp"
                        android:minWidth="96dp"
                        android:spinnerMode="dropdown"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_dropdown"
                        android:dropDownVerticalOffset="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Wave Cutout -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_marginTop="-24dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_wave_bottom"
                android:elevation="0dp"
                android:clickable="false"
                android:focusable="false" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="160dp"
        android:paddingTop="8dp"
        android:elevation="0dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_chat_message" />

    <LinearLayout
        android:id="@+id/chatInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:orientation="vertical">

        <!-- Voice Status Bar (Integrated) -->
        <LinearLayout
            android:id="@+id/voiceStatusBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="-12dp"
            android:background="@drawable/bg_stats_premium_card"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <!-- Pulsing dot indicator -->
            <View
                android:id="@+id/voiceDot"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_pill_grey"
                android:backgroundTint="@color/ef_primary" />

            <!-- Live transcript / status text -->
            <TextView
                android:id="@+id/tvVoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Đang lắng nghe..."
                android:textColor="@color/ef_text_primary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatInputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stats_premium_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="8dp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <!-- Mic Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMic"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_mic_idle"
                    android:contentDescription="Nhấn để nói"
                    android:elevation="6dp"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_mic"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Hỏi Flow bất cứ điều gì..."
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="5"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/ef_text_primary"
                    android:textColorHint="@color/ef_text_secondary"
                    android:textSize="15sp" />

                <!-- Send Button (3D White Embossed) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:padding="0dp"
                    android:background="@drawable/bg_button_send_3d_white"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_back_arrow"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="#0F172A"
                    android:elevation="6dp"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

