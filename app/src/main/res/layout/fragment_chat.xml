<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_learn_gradient_premium">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/chatHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Section with Gradient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_home_premium"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <!-- Header Actions Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Online Status Badge (3D White) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_3d_badge_silver"
                        android:elevation="4dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_pill_grey"
                            android:backgroundTint="@color/ef_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Flow Online"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- History Button (3D White) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHistory"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_history"
                        app:iconSize="22dp"
                        app:iconTint="@color/ef_text_primary"
                        app:iconGravity="textStart"
                        android:elevation="4dp" />

                    <!-- New Chat Button (3D White) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNewChat"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="12dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_add"
                        app:iconSize="22dp"
                        app:iconTint="@color/ef_text_primary"
                        app:iconGravity="textStart"
                        android:elevation="4dp" />
                </LinearLayout>

                <!-- Page Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:letterSpacing="-0.03"
                    android:lineSpacingExtra="4dp"
                    android:text="Nói chuyện với Flow"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.85"
                    android:text="Nâng trình giao tiếp cùng trợ lý AI thông minh"
                    android:textColor="@color/ef_hero_text_white"
                    android:textSize="13sp" />

                <!-- Topic Selector Card (3D White) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_3d_badge_silver"
                    android:elevation="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="2dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯"
                        android:textSize="16sp" />

                    <Spinner
                        android:id="@+id/spinnerTopic"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginStart="6dp"
                        android:background="@null"
                        android:dropDownWidth="220dp"
                        android:minWidth="120dp"
                        android:spinnerMode="dropdown"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_dropdown"
                        android:dropDownVerticalOffset="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Wave Cutout -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="-40dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_wave_bottom" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="160dp"
        android:paddingTop="12dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_chat_message" />

    <!-- Premium Floating Input Bar -->
    <LinearLayout
        android:id="@+id/chatInputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="96dp"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/chatInputCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stats_premium_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="8dp"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Hỏi Flow bất cứ điều gì..."
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLines="5"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="12dp"
                    android:textColor="@color/ef_text_primary"
                    android:textColorHint="@color/ef_text_secondary"
                    android:textSize="15sp" />

                <!-- Send Button (3D White Embossed) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:padding="0dp"
                    android:background="@drawable/bg_button_send_3d_white"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_back_arrow"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="#0F172A"
                    android:elevation="6dp"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
