<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_background"
    android:fitsSystemWindows="false"
    android:orientation="vertical">

    <!-- Header / Top Bar -->
    <RelativeLayout
        android:id="@+id/leaderboardHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_home_premium"
        android:paddingStart="16dp"
        android:paddingTop="48dp"
        android:paddingEnd="16dp"
        android:paddingBottom="45dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="22dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clipToPadding="false">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_3d_badge_silver"
                app:backgroundTint="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                app:icon="@drawable/ic_back_arrow"
                app:iconTint="@color/ef_text_primary"
                app:iconSize="20dp"
                app:iconGravity="textStart" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"
            android:text="Bảng Xếp Hạng"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black" />
    </RelativeLayout>

    <!-- Podium Section (Top 3) with Premium Styling -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-35dp"
        android:gravity="bottom"
        android:orientation="horizontal"
        android:paddingBottom="10dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Rank 2 -->
        <LinearLayout
            android:id="@+id/podium2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥈"
                android:textSize="20sp" />
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:elevation="6dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/rank2Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                    android:src="@drawable/user_avatar" />

                <TextView
                    android:id="@+id/rank2Initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="B"
                    android:textColor="@color/white"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/rank2Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="User 2"
                android:textColor="@color/ef_text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:id="@+id/rank2Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="@color/ef_card_blue_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Rank 1 -->
        <LinearLayout
            android:id="@+id/podium1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👑"
                android:textSize="32sp" />
            <FrameLayout
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_icon_circle_amber"
                android:elevation="12dp"
                android:padding="3dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_icon_circle_amber">
                     <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/rank1Avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="2dp"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                        android:src="@drawable/user_avatar" />

                     <TextView
                        android:id="@+id/rank1Initial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="A"
                        android:textColor="@color/white"
                        android:textSize="36sp"
                        android:fontFamily="sans-serif-black"
                        android:visibility="gone" />
                </FrameLayout>
            </FrameLayout>
            <TextView
                android:id="@+id/rank1Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Champion"
                android:textColor="@color/ef_text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:id="@+id/rank1Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="@color/ef_card_amber_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Rank 3 -->
        <LinearLayout
            android:id="@+id/podium3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="invisible">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥉"
                android:textSize="18sp" />
            <FrameLayout
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_icon_circle_rose"
                android:elevation="5dp">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/rank3Avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                    android:src="@drawable/user_avatar" />

                <TextView
                    android:id="@+id/rank3Initial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="C"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:visibility="gone" />
            </FrameLayout>
            <TextView
                android:id="@+id/rank3Name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="User 3"
                android:textColor="@color/ef_text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black" />
            <TextView
                android:id="@+id/rank3Score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 XP"
                android:textColor="@color/ef_card_rose_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="12dp"
        android:background="@color/ef_divider" />

    <!-- Day/Month/Week Selection (Refined 3D Buttons) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDay"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/ef_primary"
            android:elevation="4dp"
            android:text="Ngày"
            android:textColor="@color/white"
            android:fontFamily="sans-serif-black"
            app:cornerRadius="15dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWeek"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/ef_surface"
            android:elevation="4dp"
            android:text="Tuần"
            android:textColor="@color/ef_text_secondary"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="15dp"
            app:strokeColor="@color/ef_outline"
            app:strokeWidth="1.5dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMonth"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:backgroundTint="@color/ef_surface"
            android:elevation="4dp"
            android:text="Tháng"
            android:textColor="@color/ef_text_secondary"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="15dp"
            app:strokeColor="@color/ef_outline"
            app:strokeWidth="1.5dp" />
    </LinearLayout>

    <!-- Table Header Label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_table_header"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="45dp"
            android:layout_height="wrap_content"
            android:text="Hạng"
            android:textColor="@color/ef_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Tên người dùng"
            android:textColor="@color/ef_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Điểm số"
            android:textColor="@color/ef_text_secondary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:textAllCaps="true"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- Content Area: RecyclerView and Sticky MyRank -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- List for others -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLeaderboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:layout_above="@+id/stickyMyRank"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="16dp" />

        <!-- Sticky My Rank Footer -->
        <LinearLayout
            android:id="@+id/stickyMyRank"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_sticky_user_rank"
            android:elevation="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/myRank"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_3d_badge_silver">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/myAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="2dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                    android:src="@drawable/user_avatar" />

                <TextView
                    android:id="@+id/myInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="H"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/myName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="hoanghehe21"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-black" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:text="Vị trí của bạn"
                    android:textColor="@color/ef_white_silver"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/myScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150 XP"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
