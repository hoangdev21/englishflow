<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileEcoBubbleCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="18dp"
    android:background="@drawable/bg_eco_orb_glass"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="#55FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <FrameLayout
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:background="@drawable/bg_eco_orb_ring"
            android:padding="2dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/profileEcoRing"
                style="@style/Widget.MaterialComponents.CircularProgressIndicator"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="false"
                app:indicatorColor="@color/ef_primary_light"
                app:indicatorInset="0dp"
                app:indicatorSize="70dp"
                app:trackColor="#55BDE2D4"
                app:trackThickness="6dp" />

            <ImageView
                android:id="@+id/profileEcoMascot"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:contentDescription="Eco mascot"
                android:src="@drawable/eco_parrot_classic" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/profileEcoStage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eco • Mầm cánh Lv.1"
                android:textColor="@color/ef_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileEcoMood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_eco_chip"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Tò mò khám phá"
                android:textColor="@color/ef_primary_dark"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/profileEcoMissionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Nhiệm vụ hôm nay: 0/4"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenEcoSanctuary"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:background="@drawable/bg_eco_button_primary"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="14dp"
            android:text="Mở"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_nav_profile"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="14dp"
            app:iconTint="@android:color/white" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
