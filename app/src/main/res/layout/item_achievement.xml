<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="2dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/achievementContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_stats_premium_card"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- 3D Achievement Badge Container (Embossed look) -->
        <FrameLayout
            android:id="@+id/iconFrame"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_3d_badge_silver">

            <TextView
                android:id="@+id/achievementIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:paddingBottom="4dp"
                android:text="⭐"
                android:textSize="26sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/achievementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="-0.01"
                android:textColor="@color/ef_primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:shadowColor="#40000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="2" />

            <TextView
                android:id="@+id/achievementDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:alpha="0.85"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="1dp" />
        </LinearLayout>

        <!-- Status Chip (3D Glassmorphism / Silver) -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/achievementState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_3d_badge_silver"
                android:paddingStart="14dp"
                android:paddingTop="6dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textColor="@color/ef_primary_dark"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />
        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
