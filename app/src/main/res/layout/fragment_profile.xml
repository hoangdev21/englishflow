<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_learn_gradient_premium">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll">

            <!-- Hero Section (3D Gradient) -->
            <LinearLayout
                android:id="@+id/profileHeaderContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_hero_gamified"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="8dp"
                android:paddingEnd="24dp"
                android:paddingBottom="50dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hồ sơ học tập"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Avatar with 3D Frame -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="40dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_3d_badge_silver"
                            android:gravity="center"
                            android:padding="3dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/profileAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/user_avatar"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/profileName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.01" />

                            <include
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                layout="@layout/component_profile_level_badge" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/profileLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:alpha="0.85"
                            android:textColor="@color/ef_hero_text_white"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- Settings Button (3D White) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenSettings"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        app:icon="@drawable/ic_settings"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconSize="20dp"
                        app:iconTint="@color/ef_primary"
                        android:elevation="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Wave Cutout -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="-40dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_wave_bottom" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:behavior_overlapTop="30dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="130dp">

            <!-- Stats Grid (3D Embossed Cards) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:elevation="18dp"
                android:translationZ="15dp"
                android:orientation="horizontal">

                <!-- Learned Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_stats_premium_card"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="6dp"
                        android:src="@drawable/dictionary"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/tvLearnedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#0D9488"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Từ vựng"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:alpha="0.8" />
                </LinearLayout>

                <!-- Streak Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_stats_premium_card"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="6dp"
                        android:src="@drawable/fire"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvStreakCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#EA580C"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Chuỗi"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:alpha="0.8" />
                </LinearLayout>

                <!-- XP Card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stats_premium_card"
                    android:elevation="6dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="14dp"
                    android:paddingHorizontal="8dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginBottom="6dp"
                        android:src="@drawable/high_score"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/tvXpCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#CA8A04"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="XP/Tuần"
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:alpha="0.8" />
                </LinearLayout>
            </LinearLayout>

            <!-- Detailed Stats Section (3D Silver Card) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_stats_premium_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THỐNG KÊ CHI TIẾT"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="18dp" />

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins">

                    <!-- Learned -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_nav_learn"
                            android:padding="6dp"
                            android:background="@drawable/bg_icon_circle_emerald"
                            app:tint="@color/ef_stat_vocab" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvDetailLearned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Từ đã học"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Scanned -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_search_premium"
                            android:padding="6dp"
                            android:background="@drawable/bg_icon_circle_blue"
                            app:tint="@color/ef_stat_chat" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvDetailScanned"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ảnh đã quét"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Chats -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_nav_chat"
                            android:padding="6dp"
                            android:background="@drawable/bg_icon_circle_amber"
                            app:tint="@color/ef_stat_streak" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvDetailChats"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cuộc hội thoại"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Best Streak -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_history"
                            android:padding="6dp"
                            android:background="@drawable/bg_icon_circle_rose"
                            app:tint="@color/ef_stat_best_streak" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvDetailBestStreak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chuỗi cao nhất"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </GridLayout>
            </LinearLayout>

            <!-- Weekly Chart (Styled) -->
            <LinearLayout
                android:id="@+id/profileWeeklyChartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_stats_premium_card"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 NGÀY GẦN NHẤT (Phút)"
                    android:textColor="@color/ef_primary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:id="@+id/chartContainer"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:gravity="bottom"
                    android:orientation="horizontal" />

                <include
                    layout="@layout/component_profile_empty_state" />
            </LinearLayout>

            <!-- Achievements (Compact 3D Section) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Thành tựu đạt được"
                android:textColor="@color/ef_primary_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/achievementRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false" />

            <!-- View Saved Dictionary Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewSavedDictionary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                app:backgroundTint="@color/ef_primary"
                app:cornerRadius="16dp"
                android:text="Xem từ điển đã lưu"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="2dp" />

            <!-- Action Buttons (Premium 3D Silver List) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Reset Button (3D Red) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetProgress"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_raised_error"
                    app:backgroundTint="@null"
                    android:text="Đặt lại học tập"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_replace"
                    app:iconPadding="8dp"
                    app:iconSize="18dp"
                    app:iconTint="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />

                <!-- Logout Button (3D White) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_button_raised_white"
                    app:backgroundTint="@null"
                    android:text="Đăng xuất"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_logout"
                    app:iconPadding="8dp"
                    app:iconSize="18dp"
                    app:iconTint="@color/ef_text_secondary"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
