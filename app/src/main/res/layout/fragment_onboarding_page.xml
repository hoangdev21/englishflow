<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Emoji Icon -->
    <TextView
        android:id="@+id/onboardingEmoji"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:gravity="center"
        android:textSize="48sp"
        android:layout_marginBottom="36dp"
        android:background="@drawable/bg_onboarding_emoji"
        android:contentDescription="Onboarding icon" />

    <!-- Title -->
    <TextView
        android:id="@+id/onboardingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/ef_text_primary"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboardingDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/ef_text_secondary"
        android:lineSpacingExtra="5dp" />
</LinearLayout>
