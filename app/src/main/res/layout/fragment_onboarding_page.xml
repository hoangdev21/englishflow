<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp">

    <!-- Whale Animation Container -->
    <FrameLayout
        android:id="@+id/whaleContainer"
        android:layout_width="280dp"
        android:layout_height="220dp"
        android:layout_marginBottom="24dp">

        <!-- Back Wave -->
        <ImageView
            android:id="@+id/waveBack"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_gravity="bottom"
            android:src="@drawable/bg_splash_wave_mid"
            android:alpha="0.4"
            android:scaleType="fitXY" />

        <!-- Whale Lottie Animation -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/whaleLottie"
            android:layout_width="170dp"
            android:layout_height="170dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="#1A000000" />

        <!-- Front Wave -->
        <ImageView
            android:id="@+id/waveFront"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_gravity="bottom"
            android:src="@drawable/bg_splash_wave_front_new"
            android:alpha="0.8"
            android:scaleType="fitXY" />

    </FrameLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/onboardingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/ef_text_primary"
        android:letterSpacing="-0.02"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboardingDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="15sp"
        android:textColor="@color/ef_text_secondary"
        android:lineSpacingExtra="5dp" />
</LinearLayout>
