<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ef_background">

    <!-- ViewPager -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/onboardingViewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:gravity="center_horizontal">

        <!-- Custom Stepper (1-2-3-4 connected) -->
        <LinearLayout
            android:id="@+id/onboardingStepper"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Step 1 -->
            <TextView
                android:id="@+id/step1"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_active"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/line1"
                android:layout_width="32dp"
                android:layout_height="2.5dp"
                android:background="@color/ef_outline"
                android:layout_marginHorizontal="4dp" />

            <!-- Step 2 -->
            <TextView
                android:id="@+id/step2"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/ef_text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/line2"
                android:layout_width="32dp"
                android:layout_height="2.5dp"
                android:background="@color/ef_outline"
                android:layout_marginHorizontal="4dp" />

            <!-- Step 3 -->
            <TextView
                android:id="@+id/step3"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/ef_text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/line3"
                android:layout_width="32dp"
                android:layout_height="2.5dp"
                android:background="@color/ef_outline"
                android:layout_marginHorizontal="4dp" />

            <!-- Step 4 -->
            <TextView
                android:id="@+id/step4"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_step_inactive"
                android:gravity="center"
                android:text="4"
                android:textColor="@color/ef_text_tertiary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Buttons Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Bỏ qua"
                android:textColor="@color/ef_text_secondary"
                app:backgroundTint="@color/transparent"
                android:background="@drawable/bg_button_premium_outlined"
                app:cornerRadius="16dp"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="62dp"
                android:layout_weight="1.6"
                android:text="Tiếp tục"
                android:textColor="@color/white"
                app:backgroundTint="@color/transparent"
                android:background="@drawable/bg_button_premium_primary"
                app:cornerRadius="16dp"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
