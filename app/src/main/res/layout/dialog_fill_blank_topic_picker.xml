<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_premium"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="14dp">

    <View
        android:layout_width="38dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:alpha="0.4"
        android:background="@drawable/bg_pill_grey" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp">

        <TextView
            android:id="@+id/tvFillBlankTopicTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/nunito"
            android:letterSpacing="-0.01"
            android:text="@string/fill_blank_select_topic_title"
            android:textColor="@color/ef_text_primary"
            android:textSize="23sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFillBlankTopicSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/nunito"
            android:text="@string/fill_blank_topic_picker_subtitle"
            android:textColor="@color/ef_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleFillBlankTabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:checkedButton="@+id/tabFillBlankNotStarted"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabFillBlankNotStarted"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:fontFamily="@font/nunito"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Chưa luyện"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabFillBlankInProgress"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:fontFamily="@font/nunito"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Đang luyện"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tabFillBlankCompleted"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:fontFamily="@font/nunito"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Hoàn thành"
                android:textSize="11sp"
                android:textStyle="bold" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@color/ef_divider" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFillBlankTopics"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

</LinearLayout>
