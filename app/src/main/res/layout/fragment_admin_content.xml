<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/ef_background"
        android:orientation="vertical">

        <!-- Content Area -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/ef_background"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingEnd="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/nunito"
                    android:text="@string/admin_content_title"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/nunito"
                    android:text="@string/admin_content_subtitle"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/nunito"
                    android:text="@string/admin_content_shortcuts_title"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminShortcutAddWord"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0"
                        android:text="@string/admin_content_shortcut_add_word"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/book_new"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="16dp"
                        app:iconTint="@null"
                        app:strokeColor="@color/ef_outline"
                        app:strokeWidth="1.2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminShortcutAddJourney"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0"
                        android:text="@string/admin_content_shortcut_add_journey"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/goal"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="16dp"
                        app:iconTint="@null"
                        app:strokeColor="@color/ef_outline"
                        app:strokeWidth="1.2dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminShortcutOpenManager"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0"
                        android:text="@string/admin_content_shortcut_manager"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="14dp"
                        app:icon="@drawable/creativity"
                        app:iconGravity="textStart"
                        app:iconPadding="6dp"
                        app:iconSize="16dp"
                        app:iconTint="@null"
                        app:strokeColor="@color/ef_outline"
                        app:strokeWidth="1.2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminSectionVocabulary"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_3d_white"
                        android:fontFamily="@font/nunito"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0"
                        android:text="@string/admin_content_section_vocabulary"
                        android:textAllCaps="false"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:icon="@drawable/book"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="16dp"
                        app:iconTint="@null" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/adminSectionJourney"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_admin_3d_primary"
                        android:fontFamily="@font/nunito"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:letterSpacing="0"
                        android:text="@string/admin_content_section_journey"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:icon="@drawable/work"
                        app:iconGravity="textStart"
                        app:iconPadding="4dp"
                        app:iconSize="16dp"
                        app:iconTint="@null" />
                </LinearLayout>

                <!-- Stats Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/ef_card_blue"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/nunito"
                                    android:text="@string/admin_content_stat_words"
                                    android:textColor="@color/ef_card_blue_text"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/adminStatVocabularyCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/nunito"
                                    android:text="372"
                                    android:textColor="@color/ef_text_primary"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/ef_card_amber"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/nunito"
                                    android:text="@string/admin_content_stat_domains"
                                    android:textColor="@color/ef_card_amber_text"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/adminStatDomainCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/nunito"
                                    android:text="16"
                                    android:textColor="@color/ef_text_primary"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/ef_card_indigo"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/nunito"
                                    android:text="@string/admin_content_stat_topics"
                                    android:textColor="@color/ef_card_indigo_text"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/adminStatTopicCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/nunito"
                                    android:text="240"
                                    android:textColor="@color/ef_text_primary"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            app:cardBackgroundColor="@color/ef_card_rose"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/nunito"
                                    android:text="@string/admin_content_stat_locked"
                                    android:textColor="@color/ef_card_rose_text"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/adminStatLockedCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/nunito"
                                    android:text="0"
                                    android:textColor="@color/ef_text_primary"
                                    android:textSize="32sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <!-- Status Summary -->
                <TextView
                    android:id="@+id/adminJourneySummaryChip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_chip_soft"
                    android:fontFamily="@font/nunito"
                    android:paddingStart="20dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="12dp"
                    android:text="Lesson hành trình: 10 | Hiển thị: 10 | Ẩn: 0"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adminBtnPrimaryAction"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_admin_3d_primary"
                    android:fontFamily="@font/nunito"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0"
                    android:text="@string/admin_content_add_word"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/white" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/adminBtnContent"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_admin_3d_white"
                    android:fontFamily="@font/nunito"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:letterSpacing="0"
                    android:text="@string/admin_content_open_advanced_manager"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_edit"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/ef_primary" />

                <TextView
                    android:id="@+id/adminSearchLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/nunito"
                    android:text="@string/admin_content_search_label"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Search and Filter -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/adminSearchInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxStrokeColor="@color/ef_outline"
                    app:boxStrokeWidth="1.2dp"
                    app:endIconMode="clear_text"
                    app:hintEnabled="false"
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="@color/ef_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/adminVocabSearchInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:fontFamily="@font/nunito"
                        android:hint="@string/admin_content_search_hint"
                        android:inputType="text"
                        android:paddingStart="4dp"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Vocabulary Panel UI hidden fields if needed (Domain filter dropdown) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/adminDomainFilterLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"
                    app:boxBackgroundColor="@color/white"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="20dp"
                    app:boxCornerRadiusBottomStart="20dp"
                    app:boxCornerRadiusTopEnd="20dp"
                    app:boxCornerRadiusTopStart="20dp"
                    app:boxStrokeColor="@color/ef_outline"
                    app:boxStrokeWidth="1.2dp"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/adminDomainFilterInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:dropDownHeight="280dp"
                        android:dropDownVerticalOffset="6dp"
                        android:fontFamily="@font/nunito"
                        android:hint="@string/admin_content_domain_filter_hint"
                        android:inputType="none"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- List Caption -->
                <TextView
                    android:id="@+id/adminVocabResultCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/nunito"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp"
                    tools:text="Hiển thị 10 / 10 từ" />

                <TextView
                    android:id="@+id/adminJourneyResultCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/nunito"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="Hiển thị 10 / 10 lesson" />

                <!-- Recycler Content -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:id="@+id/adminVocabularyPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/adminVocabRecycler"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="true"
                                android:paddingBottom="20dp" />

                            <TextView
                                android:id="@+id/adminVocabEmptyState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="40dp"
                                android:gravity="center"
                                android:text="@string/admin_content_empty"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="14sp"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/adminJourneyPanel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/adminJourneyRecycler"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:nestedScrollingEnabled="true"
                                android:paddingBottom="20dp" />

                            <TextView
                                android:id="@+id/adminJourneyEmptyState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="40dp"
                                android:gravity="center"
                                android:text="@string/admin_content_journey_empty"
                                android:textColor="@color/ef_text_secondary"
                                android:textSize="14sp"
                                android:visibility="gone" />
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
