<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_map_card_bg">

    <!-- Hero Section (Fixed) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mapHeroSection"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:clipChildren="false"
        android:background="@drawable/bg_map_hero_gradient"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Background Glow behind the AI -->
        <View
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:background="@drawable/bg_bot_halo"
            android:alpha="0.4"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Status Badges (Premium Glass Design) -->
        <TextView
            android:id="@+id/mapLangChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_badge_white_alpha"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="EN"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:elevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:elevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_badge_white_alpha"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="🔥 12"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_white_alpha"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="PRO"
                android:textColor="#FFDA44"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- AI Bot Hero View -->
        <ImageView
            android:id="@+id/mapHeroAvatar"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginBottom="-10dp"
            android:contentDescription="AI Avatar"
            android:scaleType="fitCenter"
            android:src="@drawable/chat_bot_avatar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Floating Speak Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/mapSpeakQuickButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/ef_success"
            android:text="@string/learn_map_speak"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="26dp"
            app:elevation="8dp"
            app:icon="@drawable/ic_volume_up"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content Section -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mapHeroSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="64dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp" 
                app:cardBackgroundColor="@color/ef_surface"
                app:cardCornerRadius="32dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/ef_outline_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="32dp">

                    <!-- Content Header with decorative lines -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/ef_outline" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="16dp"
                            android:text="@string/learn_map_title"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-black"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/ef_outline" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="@string/learn_map_subtitle"
                        android:textColor="@color/ef_text_tertiary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Learning Map Container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <com.example.englishflow.ui.views.MapPathView
                            android:id="@+id/mapPathView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <LinearLayout
                            android:id="@+id/mapNodesContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </FrameLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
