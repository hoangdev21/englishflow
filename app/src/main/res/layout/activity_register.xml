<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="-74dp"
        android:layout_marginStart="-56dp"
        android:background="@drawable/bg_auth_orb_top"
        android:importantForAccessibility="no" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-92dp"
        android:layout_marginBottom="-102dp"
        android:background="@drawable/bg_auth_orb_bottom"
        android:importantForAccessibility="no" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_auth_brand_chip"
                android:paddingStart="14dp"
                android:paddingTop="7dp"
                android:paddingEnd="14dp"
                android:paddingBottom="7dp"
                android:text="CREATE ACCOUNT"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/nunito"
                android:gravity="center"
                android:text="Bắt đầu hành trình mới"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:alpha="0.9"
                android:gravity="center"
                android:text="Tạo tài khoản để lưu tiến độ học và đồng bộ trên mọi thiết bị"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Tên hiển thị"
                    android:textColorHint="#CCFFFFFF"
                    app:boxBackgroundColor="#17FFFFFF"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="#70FFFFFF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#CCFFFFFF"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:startIconTint="#E6FFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/registerNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/white"
                        android:textColorHint="#CCFFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Email"
                    android:textColorHint="#CCFFFFFF"
                    app:boxBackgroundColor="#17FFFFFF"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="#70FFFFFF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintTextColor="#CCFFFFFF"
                    app:startIconDrawable="@android:drawable/ic_dialog_email"
                    app:startIconTint="#E6FFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/registerEmailInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/white"
                        android:textColorHint="#CCFFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Mật khẩu"
                    android:textColorHint="#CCFFFFFF"
                    app:boxBackgroundColor="#17FFFFFF"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="#70FFFFFF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#E6FFFFFF"
                    app:hintTextColor="#CCFFFFFF"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#E6FFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/registerPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#CCFFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Nhập lại mật khẩu"
                    android:textColorHint="#CCFFFFFF"
                    app:boxBackgroundColor="#17FFFFFF"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="#70FFFFFF"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#E6FFFFFF"
                    app:hintTextColor="#CCFFFFFF"
                    app:startIconDrawable="@android:drawable/ic_lock_lock"
                    app:startIconTint="#E6FFFFFF">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/registerConfirmPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/white"
                        android:textColorHint="#CCFFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:backgroundTint="@color/white"
                    android:text="@string/auth_register"
                    android:textColor="@color/ef_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnGoToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:text="Đã có tài khoản? Đăng nhập"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
