<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="48dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- AI Avatar (3D Silver) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_3d_badge_silver"
            android:padding="2dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/chat_bot_avatar"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- AI Bubble -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_ai_premium"
            android:elevation="2dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/chatAiMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ef_text_primary"
                android:textSize="15sp"
                android:lineSpacingExtra="5dp"
                android:letterSpacing="0.01" />
        </LinearLayout>

        <!-- Vocabulary Action Bar — shown only when AI returns vocab data -->
        <LinearLayout
            android:id="@+id/vocabActionBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_stats_premium_card"
            android:elevation="4dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <!-- Word chip -->
            <TextView
                android:id="@+id/tvVocabWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:textColor="@color/ef_primary_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <!-- IPA chip -->
            <TextView
                android:id="@+id/tvVocabIpa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_chip_soft"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:background="@color/ef_text_secondary"
                android:alpha="0.25" />

            <!-- Speaker Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSpeak"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:contentDescription="Phát âm"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_volume_up"
                app:iconSize="18dp"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:elevation="2dp" />

            <!-- Save to Dictionary Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveVocab"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:background="@drawable/bg_icon_circle_emerald"
                android:contentDescription="Lưu vào từ điển"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_bookmark"
                app:iconSize="18dp"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                android:elevation="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/vocabDetailBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/tvVocabMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="270dp"
                android:textColor="@color/ef_text_primary"
                android:textSize="13.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVocabExample"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxWidth="270dp"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12.5sp"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tvVocabExampleVi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:maxWidth="270dp"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp"
                android:alpha="0.85"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- Correction block (3D Silver Card) -->
        <LinearLayout
            android:id="@+id/correctionBlock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_stats_premium_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/correctionText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ef_primary_dark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_nav_learn"
                android:drawablePadding="8dp"
                app:drawableTint="@color/ef_primary" />

            <TextView
                android:id="@+id/correctionExplain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:maxWidth="260dp"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12.5sp"
                android:alpha="0.85"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
