<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/learn_fields"
        android:textAppearance="@style/TextAppearance.EnglishFlow.Title" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="14dp"
        android:text="Chọn lĩnh vực bạn muốn tập trung hôm nay"
        android:textColor="@color/ef_text_secondary"
        android:textSize="13sp"
        android:lineSpacingExtra="2dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/domainRecycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:spanCount="2" />

</LinearLayout>
