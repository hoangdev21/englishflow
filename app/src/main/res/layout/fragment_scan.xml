<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_learn_gradient_premium">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_home_premium"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="55dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="1"
                    android:background="@drawable/bg_3d_badge_silver"
                    android:elevation="4dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="7dp"
                    android:text="AI VISION"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:letterSpacing="-0.03"
                    android:lineSpacingExtra="4dp"
                    android:text="Trợ lý Thị giác"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.85"
                    android:text="Quét bất cứ thứ gì để học tiếng Anh chuyên nghiệp"
                    android:textColor="@color/ef_hero_text_white"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="-40dp"
                android:scaleType="fitXY"
                android:src="@drawable/bg_wave_bottom" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">

            <!-- Camera Frame -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="320dp"
                app:cardBackgroundColor="@color/black"
                app:cardCornerRadius="36dp"
                app:cardElevation="10dp"
                app:strokeWidth="5dp"
                app:strokeColor="@color/ef_silver_border"
                android:layout_marginHorizontal="2dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.camera.view.PreviewView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <ImageView
                        android:id="@+id/scanPreview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                    
                    <View
                        android:id="@+id/scanLine"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:background="@drawable/bg_scan_line"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="24dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="10dp"
                        android:elevation="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Căn chỉnh vật thể vào giữa"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3D Control Panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-38dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:elevation="20dp"
                android:clipToPadding="false"
                android:paddingBottom="10dp">

                <!-- Gallery Button (3D White) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="33dp"
                    app:cardBackgroundColor="@android:color/transparent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickGallery"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_gallery"
                        app:iconTint="@color/ef_text_primary"
                        app:iconSize="28dp"
                        app:iconGravity="textStart" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Take Photo Button -->
                <ImageButton
                    android:id="@+id/btnTakePhoto"
                    android:layout_width="98dp"
                    android:layout_height="98dp"
                    android:layout_marginHorizontal="22dp"
                    android:background="@drawable/ic_lens_orb"
                    android:elevation="15dp"
                    android:padding="0dp"
                    android:scaleType="centerInside" />

                <!-- AI Analyze Button (3D White) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="66dp"
                    android:layout_height="66dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="33dp"
                    app:cardBackgroundColor="@android:color/transparent">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalyzeAi"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:insetLeft="0dp"
                        android:insetRight="0dp"
                        android:background="@drawable/bg_3d_badge_silver"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_ai_stars"
                        app:iconTint="@color/ef_text_primary"
                        app:iconSize="28dp"
                        app:iconGravity="textStart" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/scanLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:visibility="gone"
                app:indicatorColor="@color/ef_primary"
                app:trackColor="@color/ef_silver_border"
                app:trackCornerRadius="6dp"
                app:trackThickness="10dp"
                android:indeterminate="true" />

            <!-- Result Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_stats_premium_card"
                    android:orientation="vertical"
                    android:padding="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="26dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/scanWord"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ceiling"
                                    android:textColor="@color/ef_text_primary"
                                    android:textSize="38sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="-0.03" />
                                
                                <TextView
                                    android:id="@+id/scanIpa"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="/ˈsiː.lɪŋ/"
                                    android:textColor="@color/ef_text_secondary"
                                    android:textSize="16sp" />
                            </LinearLayout>

                            <!-- Speaker Button (3D White Background, Blue Icon) -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                app:cardElevation="0dp"
                                app:cardCornerRadius="32dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                android:clipToPadding="false">
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnPronounceScan"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_3d_badge_silver"
                                    app:backgroundTint="@null"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:insetLeft="0dp"
                                    android:insetRight="0dp"
                                    app:icon="@drawable/ic_volume_up"
                                    app:iconTint="@color/ef_card_blue_text"
                                    app:iconSize="32dp"
                                    app:iconGravity="textStart" />
                            </com.google.android.material.card.MaterialCardView>
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/scanMeaning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="Trần nhà"
                            android:textColor="@color/ef_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="24dp"
                            android:background="@color/ef_divider" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CÔNG THỨC &amp; VÍ DỤ"
                            android:textColor="@color/ef_text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/scanExample"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:text="The ceiling in the room is very high."
                            android:textColor="@color/ef_text_primary"
                            android:textSize="16sp"
                            android:lineSpacingExtra="5dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="26dp"
                            android:background="@drawable/bg_stats_premium_card"
                            android:padding="2dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="18dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="💡 HỮU ÍCH"
                                    android:textColor="@color/ef_primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />
                                <TextView
                                    android:id="@+id/scanFunFact"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="The ceiling is the upper interior surface of a room or building."
                                    android:textColor="@color/ef_text_secondary"
                                    android:textSize="13sp"
                                    android:lineSpacingExtra="3dp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Action Row (White Theme) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="32dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <!-- Save Button (3D White) -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="62dp"
                                android:layout_weight="1"
                                app:cardElevation="0dp"
                                app:cardCornerRadius="31dp"
                                app:cardBackgroundColor="@android:color/transparent">
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnSaveScan"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_3d_badge_silver"
                                    app:backgroundTint="@null"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:insetLeft="0dp"
                                    android:insetRight="0dp"
                                    android:text="LƯU VÀO SỔ TAY"
                                    android:textColor="@color/ef_text_primary"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:letterSpacing="0.02" />
                            </com.google.android.material.card.MaterialCardView>

                            <!-- History Button (3D White) -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="62dp"
                                android:layout_height="62dp"
                                android:layout_marginStart="14dp"
                                app:cardElevation="0dp"
                                app:cardCornerRadius="31dp"
                                app:cardBackgroundColor="@android:color/transparent">
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnManageCustomWords"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:insetLeft="0dp"
                                    android:insetRight="0dp"
                                    android:background="@drawable/bg_3d_badge_silver"
                                    app:backgroundTint="@null"
                                    app:icon="@drawable/ic_history"
                                    app:iconTint="@color/ef_text_primary"
                                    app:iconSize="28dp"
                                    app:iconGravity="textStart" />
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                        
                        <!-- Hidden meta-data views -->
                        <TextView android:id="@+id/scanWordType" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanExampleVi" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanConfidence" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanCategory" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanRelated" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanRawLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanMappedWord" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanPreviewHintTitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <TextView android:id="@+id/scanPreviewHint" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        <LinearLayout android:id="@+id/scanOverlayContainer" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
