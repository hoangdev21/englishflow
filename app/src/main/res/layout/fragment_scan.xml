<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/scan_title"
            android:textAppearance="@style/TextAppearance.EnglishFlow.Title" />

        <!-- Camera Preview -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/ef_surface_variant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ef_outline_light"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <androidx.camera.view.PreviewView
                    android:id="@+id/cameraPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/scan_preview_desc" />

                <ImageView
                    android:id="@+id/scanPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/scan_preview_desc"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_camera"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#70000000"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/scanPreviewHintTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Goi y realtime"
                        android:textColor="@android:color/white"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp"
                        android:alpha="0"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/scanPreviewHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="10dp"
                        android:background="@drawable/bg_chip_soft"
                        android:text="Hướng camera vào vật thể"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:alpha="0.9" />
                </LinearLayout>
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTakePhoto"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_take_photo"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickGallery"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/btn_pick_gallery"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Analyze Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnalyzeAi"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="@string/btn_analyze"
            android:textSize="14sp" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/scanLoading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:indicatorSize="32dp"
            app:indicatorInset="0dp" />

        <!-- ═══════════════════════════════════════════ -->
        <!-- SCAN RESULT CARD                            -->
        <!-- ═══════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/ef_surface"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ef_outline_light"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/ef_tertiary_container"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỪ ĐƯỢC QUÉT"
                            android:textColor="@color/ef_on_tertiary_container"
                            android:textSize="10sp"
                            android:letterSpacing="0.08"
                            android:alpha="0.7" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Chi tiết từ vựng"
                            android:textColor="@color/ef_on_tertiary_container"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPronounceScan"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:minWidth="40dp"
                        android:minHeight="40dp"
                        android:padding="0dp"
                        app:icon="@drawable/ic_volume_up"
                        app:iconGravity="textStart"
                        app:iconSize="20dp"
                        app:iconTint="@color/ef_primary" />
                </LinearLayout>

                <!-- Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Word Display -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="@color/ef_tertiary_container"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/scanWord"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="word"
                                android:textColor="@color/ef_on_tertiary_container"
                                android:textSize="30sp"
                                android:textStyle="bold"
                                android:letterSpacing="-0.02" />

                            <TextView
                                android:id="@+id/scanIpaMeaning"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textColor="@color/ef_on_tertiary_container"
                                android:textSize="13sp"
                                android:alpha="0.8"
                                android:lineSpacingExtra="3dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Debug Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/scanRawLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nhan tho AI: object"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="11sp"
                            android:lineSpacingExtra="1dp" />

                        <TextView
                            android:id="@+id/scanMappedWord"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Tu da map: object"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="1dp" />

                        <TextView
                            android:id="@+id/scanConfidence"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Do tin cay: 0%"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="1dp" />
                    </LinearLayout>

                    <!-- Category -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/scanCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_soft"
                            android:paddingStart="14dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="6dp"
                            android:textColor="@color/ef_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Example -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VÍ DỤ"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:cardBackgroundColor="@color/ef_surface_variant"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/scanExample"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="13sp"
                                android:padding="12dp"
                                android:lineSpacingExtra="2dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Fun Fact -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MẸO"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:cardBackgroundColor="@color/ef_primary_container"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/scanFunFact"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ef_on_primary_container"
                                android:textSize="12sp"
                                android:padding="12dp"
                                android:lineSpacingExtra="2dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Related Words -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỪ LIÊN QUAN"
                            android:textColor="@color/ef_text_tertiary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:cardBackgroundColor="@color/ef_surface_variant"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">

                            <TextView
                                android:id="@+id/scanRelated"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/ef_text_primary"
                                android:textSize="12sp"
                                android:padding="12dp"
                                android:lineSpacingExtra="2dp" />
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Save Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManageCustomWords"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:layout_marginEnd="8dp"
                            android:text="Quản lý từ"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveScan"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:text="@string/btn_save_word"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
