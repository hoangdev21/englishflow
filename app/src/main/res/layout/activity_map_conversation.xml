<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_map_convo_top">

    <!-- Top Action Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="16dp"
        android:paddingTop="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/mapConversationBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_badge_white_alpha"
            android:src="@drawable/ic_back_arrow"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <LinearLayout
            android:id="@+id/timerPanel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_badge_white_alpha"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            app:layout_constraintBottom_toBottomOf="@id/mapConversationBack"
            app:layout_constraintStart_toEndOf="@id/mapConversationBack"
            app:layout_constraintTop_toTopOf="@id/mapConversationBack">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_timer"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/mapTimerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="04:18"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/mapConversationTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="Skill: Greetings"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/mapConversationBack"
            app:layout_constraintEnd_toStartOf="@id/speedPanel"
            app:layout_constraintStart_toEndOf="@id/timerPanel"
            app:layout_constraintTop_toTopOf="@id/mapConversationBack" />

        <TextView
            android:id="@+id/speedPanel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_badge_white_alpha"
            android:gravity="center"
            android:minWidth="52dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="1x"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/mapConversationBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/mapConversationBack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Robot Mascot Display -->
    <ImageView
        android:id="@+id/robotMascot"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/chat_bot_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Progress Indicator Stack (Left) -->
    <LinearLayout
        android:id="@+id/stageProgressGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/chatPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <LinearLayout
            android:id="@+id/stageLectureRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/stageLectureDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_active" />

            <TextView
                android:id="@+id/stageLectureText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Bài giảng"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:id="@+id/stageConnector"
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:layout_marginStart="3.5dp"
            android:background="@color/white"
            android:alpha="0.4" />

        <LinearLayout
            android:id="@+id/stagePracticeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.5"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/stagePracticeDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_inactive" />

            <TextView
                android:id="@+id/stagePracticeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Luyện tập"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/heroWaveCard"
        android:layout_width="88dp"
        android:layout_height="146dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="22dp"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="10dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/chatPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="VOICE"
            android:textAllCaps="true"
            android:textColor="#E6FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_bot_halo"
                android:alpha="0.22" />

            <com.example.englishflow.ui.views.VoiceWaveformView
                android:id="@+id/heroWaveform"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom Instruction Panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/chatPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_voice_chat_surface"
        android:paddingHorizontal="24dp"
        android:paddingTop="32dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/robotMascot"
        app:layout_constraintVertical_bias="1.0">

        <LinearLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent">

            <ProgressBar
                android:id="@+id/mapProgressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressDrawable="@drawable/bg_convo_progress_bar"
                android:progress="20" />

            <TextView
                android:id="@+id/mapConversationProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="1/3"
                android:textColor="@color/ef_text_tertiary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivFinishFlag"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_check_circle"
                android:alpha="0.3"
                app:tint="@color/ef_primary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mapChatHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:divider="@android:color/transparent"
            android:paddingBottom="180dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/mapConversationProgress" />

        <!-- Gradient Fade Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_chat_fade"
            android:alpha="0.9"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Listening status -->
        <TextView
            android:id="@+id/mapListeningStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Đang lắng nghe..."
            android:textColor="@color/ef_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@id/mapBottomActions"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Bottom Actions Row -->
        <LinearLayout
            android:id="@+id/mapBottomActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingBottom="40dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/btnType"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_surface_card"
                    android:padding="12dp"
                    android:src="@drawable/ic_keyboard"
                    app:tint="@color/ef_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Loại"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/mapMicButton"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_mic_premium_blue"
                android:padding="28dp"
                android:src="@drawable/ic_mic"
                app:tint="@color/white" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/btnInspiration"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_surface_card"
                    android:padding="12dp"
                    android:src="@drawable/ic_lightbulb"
                    app:tint="@color/ef_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cảm hứng"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
