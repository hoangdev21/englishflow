<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="4dp"
    android:background="@drawable/bg_stats_premium_card"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <!-- Rank Column -->
    <TextView
        android:id="@+id/txtRank"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:gravity="start"
        android:text="4"
        android:textColor="@color/ef_text_secondary"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium" />

    <!-- Avatar Column -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="4dp"
        android:background="@drawable/bg_3d_badge_silver">
        <TextView
            android:id="@+id/txtAvatarInitial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="D"
            android:textColor="@color/ef_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Name & Info Column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="User Name"
            android:textColor="@color/ef_text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black" />
        <TextView
            android:id="@+id/txtEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.6"
            android:text="user@gmail.com"
            android:textColor="@color/ef_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Score Column -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1,250"
            android:textColor="@color/ef_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-black" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XP"
            android:textColor="@color/ef_text_tertiary"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
