<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/confettiText"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:gravity="center"
        android:text="✨ 🎉 ✨ 🎊 ✨"
        android:textColor="@color/ef_primary"
        android:textSize="44sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="🎉 Hoàn thành bộ flashcard"
        android:textColor="@color/ef_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/xpText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/ef_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Bạn đã mở khoá tiến bộ mới. Tiếp tục duy trì streak mỗi ngày nhé!"
        android:textColor="@color/ef_text_secondary"
        android:textSize="14sp" />

</LinearLayout>
