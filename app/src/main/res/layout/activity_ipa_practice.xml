<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ef_background"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBackPractice"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_premium_card_ripple"
                    android:contentDescription="@string/ipa_practice_back"
                    android:padding="10dp"
                    android:src="@drawable/back_navigation"
                    app:tint="@color/ef_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/nunito"
                    android:gravity="center"
                    android:text="@string/ipa_practice_header_title"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="44dp"
                    android:layout_height="44dp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/ef_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/ef_outline_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvPracticeTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="@font/nunito"
                            android:text="@string/ipa_practice_title_format"
                            android:textColor="@color/ef_primary_dark"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnPlaySymbol"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_premium_card_ripple"
                            android:contentDescription="@string/ipa_practice_play_symbol"
                            android:padding="8dp"
                            android:src="@drawable/ic_volume_up"
                            app:tint="@color/ef_primary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPracticeFocus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_focus_format"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvCurrentWord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip_soft"
                        android:fontFamily="@font/nunito"
                        android:paddingStart="12dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="6dp"
                        android:text="@string/ipa_practice_current_word_format"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentWordProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_chip_soft"
                        android:fontFamily="@font/nunito"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:text="@string/ipa_practice_current_word_correct_reads_format"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvPracticeMouthHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_mouth_hint_prefix"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvPracticeExerciseHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_exercise_prefix"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/nunito"
                android:text="@string/ipa_practice_words_title"
                android:textColor="@color/ef_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvWordLadderStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_chip_soft"
                android:fontFamily="@font/nunito"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="@string/ipa_practice_word_ladder_status_placeholder"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPracticeWords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingEnd="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnListenSample"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:text="@string/ipa_practice_listen_sample"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/ef_secondary"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_volume_up"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartPronounce"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:text="@string/ipa_practice_start_record"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/ef_primary"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_mic"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/ef_surface"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/ef_outline_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_result_title"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecognizedText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_recognized_placeholder"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvOverallScore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_score_overall_format"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvSoundScore"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip_soft"
                            android:fontFamily="@font/nunito"
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="@string/ipa_practice_score_sound_format"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvOnsetScore"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip_soft"
                            android:fontFamily="@font/nunito"
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="@string/ipa_practice_score_onset_format"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCodaScore"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_chip_soft"
                            android:fontFamily="@font/nunito"
                            android:gravity="center"
                            android:padding="8dp"
                            android:text="@string/ipa_practice_score_coda_format"
                            android:textColor="@color/ef_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDiagnosis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_diag_placeholder"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvExercisePlan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_exercise_placeholder"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_history_title"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAttemptHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/nunito"
                        android:text="@string/ipa_practice_history_placeholder"
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
