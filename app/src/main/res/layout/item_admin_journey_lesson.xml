<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/ef_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:rippleColor="@color/ef_outline_light"
    app:strokeColor="@color/ef_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/adminJourneyIcon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_learn_quick_action_tile"
                android:padding="6dp"
                android:scaleType="centerInside"
                android:src="@drawable/hello" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/adminJourneyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:text="Lesson title"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/adminJourneyMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:text="lesson_01 • A1 • order 1"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/adminJourneyStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_stats_premium_card"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="HIEN THI"
                android:textColor="@color/ef_card_blue_text"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/adminJourneyKeywords"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:text="Keywords: hello, morning, name"
            android:textColor="@color/ef_text_secondary"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminJourneyDetailButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="@string/admin_content_journey_detail"
                android:textAllCaps="false"
                android:textColor="@color/ef_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/ef_surface_variant"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_list"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="14dp"
                app:iconTint="@color/ef_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminJourneyEditButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="Sửa"
                android:textAllCaps="false"
                android:textColor="@color/ef_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/ef_surface_variant"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="14dp"
                app:iconTint="@color/ef_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/adminJourneyVisibilityButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:text="Ẩn"
                android:textAllCaps="false"
                android:textColor="@color/ef_text_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="@color/ef_surface_variant"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_lock_closed"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconSize="14dp"
                app:iconTint="@color/ef_card_rose_text" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/adminJourneyDeleteButton"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/admin_content_journey_delete"
            android:textAllCaps="false"
            android:textColor="@color/ef_card_rose_text"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="@color/ef_card_rose"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_delete"
            app:iconGravity="textStart"
            app:iconPadding="6dp"
            app:iconSize="14dp"
            app:iconTint="@color/ef_card_rose_text" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
