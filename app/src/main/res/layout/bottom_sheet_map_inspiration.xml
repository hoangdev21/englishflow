<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_premium"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_pill_grey"
        android:alpha="0.3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡 Ý tưởng gợi ý"
        android:textColor="@color/ef_text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Chọn một câu để trả lời Flow nhanh nhé!"
        android:textColor="@color/ef_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/suggestedContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical">

        <!-- Skeleton Loading (Optional) -->
        <ProgressBar
            android:id="@+id/suggestedLoading"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/ef_primary" />

        <TextView
            android:id="@+id/suggestedText1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_item_white_clickable"
            android:padding="16dp"
            android:text="..."
            android:textColor="@color/ef_text_primary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/suggestedText2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_item_white_clickable"
            android:padding="16dp"
            android:text="..."
            android:textColor="@color/ef_text_primary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/suggestedText3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_item_white_clickable"
            android:padding="16dp"
            android:text="..."
            android:textColor="@color/ef_text_primary"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <android.view.View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

</LinearLayout>
