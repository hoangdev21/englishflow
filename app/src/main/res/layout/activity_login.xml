<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/authLoginRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_auth_marine_premium">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-56dp"
        android:layout_marginTop="-36dp"
        android:background="@drawable/bg_auth_orb_top" />

    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-68dp"
        android:layout_marginBottom="-54dp"
        android:background="@drawable/bg_auth_orb_bottom" />

    <ScrollView
        android:id="@+id/loginScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingStart="24dp"
        android:paddingTop="56dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- App Logo -->
            <ImageView
                android:layout_width="200dp"
                android:layout_height="120dp"
                android:src="@drawable/english_flow"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:contentDescription="EnglishFlow Logo" />

            <!-- Main Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/nunito"
                android:gravity="center"
                android:text="Đăng nhập"
                android:textColor="@color/ef_text_on_dark"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <!-- Form Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/bg_auth_glass_card"
                android:paddingStart="18dp"
                android:paddingTop="20dp"
                android:paddingEnd="18dp"
                android:paddingBottom="18dp"
                android:orientation="vertical">

                <!-- Email Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/nunito"
                    android:text="Email"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Email Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/ef_surface_variant"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusTopStart="28dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:startIconDrawable="@drawable/ic_mail"
                    app:startIconTint="@color/ef_info"
                    app:startIconMinSize="44dp"
                    app:startIconScaleType="centerInside">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginEmailInput"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:hint="Nhập email của bạn"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="16sp"
                        android:gravity="center_vertical"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/nunito"
                    android:text="Mật khẩu"
                    android:textColor="@color/ef_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Password Field -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/ef_surface_variant"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusTopStart="28dp"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/ef_text_tertiary"
                    app:startIconDrawable="@drawable/ic_lock_closed"
                    app:startIconTint="@color/ef_info"
                    app:startIconMinSize="44dp"
                    app:startIconScaleType="centerInside">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/loginPasswordInput"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:hint="Nhập mật khẩu"
                        android:textColorHint="@color/ef_text_tertiary"
                        android:inputType="textPassword"
                        android:textColor="@color/ef_text_primary"
                        android:textSize="16sp"
                        android:gravity="center_vertical"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/btnForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="8dp"
                    android:text="Quên mật khẩu?"
                    android:textColor="@color/ef_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingVertical="8dp" />

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_button_raised_primary"
                    app:backgroundTint="@null"
                    android:text="@string/auth_login"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:elevation="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_raised_white"
                    app:backgroundTint="@null"
                    app:icon="@drawable/logo_gg"
                    app:iconGravity="textStart"
                    app:iconSize="22dp"
                    app:iconPadding="12dp"
                    app:iconTint="@null"
                    android:text="@string/auth_google_sign_in"
                    android:textAllCaps="false"
                    android:textColor="@color/ef_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Register Link -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="36dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có tài khoản?  "
                        android:textColor="@color/ef_text_secondary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/btnGoToRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng ký ngay"
                        android:textColor="@color/ef_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom Hero Image -->
            <ImageView
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="8dp"
                android:adjustViewBounds="true"
                android:src="@drawable/englist_hero_home"
                android:alpha="0.95"
                android:contentDescription="EnglishFlow Hero" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
