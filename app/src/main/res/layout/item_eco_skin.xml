<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="194dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/skinContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_eco_card"
        android:orientation="vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/skinPreview"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:background="@drawable/bg_eco_orb_ring"
            android:contentDescription="Eco skin"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/eco_parrot_classic" />

        <TextView
            android:id="@+id/skinName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Eco Cổ Điển"
            android:textColor="@color/ef_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/skinRarity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_eco_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Common"
            android:textColor="@color/ef_primary_dark"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/skinBonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Bonus"
            android:textColor="@color/ef_text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/skinPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="520 XP"
            android:textColor="@color/ef_primary_dark"
            android:textSize="12sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/skinActionButton"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_eco_button_outline"
            android:minHeight="0dp"
            android:text="Mở khóa"
            android:textAllCaps="false"
            android:textColor="@color/ef_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
