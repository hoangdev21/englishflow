<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/ef_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ef_outline_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dictionaryWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ef_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dictionaryMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/ef_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPronounceDictionary"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:minWidth="36dp"
            android:minHeight="36dp"
            android:padding="0dp"
            app:icon="@drawable/ic_volume_up"
            app:iconGravity="textStart"
            app:iconSize="18dp"
            app:iconTint="@color/ef_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteDictionary"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:minWidth="36dp"
            android:minHeight="36dp"
            android:padding="0dp"
            android:layout_marginStart="2dp"
            android:text="✕"
            android:textColor="@color/ef_text_tertiary"
            android:textSize="16sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
