<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/chatAiMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="42dp"
        android:background="@drawable/bg_bubble_ai"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:textColor="@color/ef_text_primary"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/correctionBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_warning_block"
        android:orientation="vertical"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/correctionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/ef_warning_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/correctionExplain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/ef_warning_text"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
